{
  "name": "exam-review-vue",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "cargo run --manifest-path server-rs/Cargo.toml --bin exam-review-api",
    "api:rust": "cargo run --manifest-path server-rs/Cargo.toml --bin exam-review-api",
    "api:js": "node server/index.js",
    "gaokao:enrich": "cargo run --manifest-path server-rs/Cargo.toml --bin gaokao-enrich-solutions --",
    "gaokao:langsmith": "node scripts/export-gaokao-langsmith-jsonl.mjs",
    "gaokao:langgraph": "node scripts/langchain/gaokao-dataset-graph.mjs",
    "db:setup": "node -e \"import('./server/db.js').then(async m=>{await m.ensureSchema(); await m.pool.end(); console.log('database schema ready')})\"",
    "db:seed:gaokao": "node server/seed-gaokao.js",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "cargo run --manifest-path server-rs/Cargo.toml --bin migrate",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "perf:benchmark": "node scripts/perf-benchmark.mjs",
    "format": "prettier --write \"src/**/*.{vue,ts,json,css}\"",
    "prepare": "husky",
    "gaokao:rag": "node scripts/langchain/gaokao-rag-graph.mjs",
    "materials:index": "node scripts/index-materials.mjs",
    "materials:index:high-school": "node scripts/index-materials.mjs --domain high-school",
    "materials:index:university": "node scripts/index-materials.mjs --domain university --root src/content"
  },
  "lint-staged": {
    "src/**/*.{vue,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.3",
    "@langchain/textsplitters": "^1.0.1",
    "3d-force-graph": "^1.80.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.4.12",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "katex": "^0.17.0",
    "langchain": "^1.5.2",
    "lucide-vue-next": "^0.468.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.6",
    "nanoid": "^5.1.16",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "playwright-core": "^1.61.1",
    "three": "^0.185.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.20.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@sentry/vue": "^10.63.0",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.0"
  }
}
